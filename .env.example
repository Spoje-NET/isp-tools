# AbraFlexi Configuration
ABRAFLEXI_URL=https://demo.flexibee.eu:5434
ABRAFLEXI_LOGIN=winstrom
ABRAFLEXI_PASSWORD=placeholder_password
ABRAFLEXI_COMPANY=demo_company

# Application Configuration
EASE_LOGGER=console|syslog
RESULT_FILE=isp_tools_result.json

# Application Behavior
APP_DEBUG=false

# AbraFlexi Labels (Pipeline A)
LABEL_DISCONNECTED=ODPOJENO
LABEL_NODISCONNECT=NEODPOJOVAT
LABEL_VIP=VIP
LABEL_THIRD_REMINDER=UPOMINKA3

# Contract filtering (empty = all active contract types)
INET_CONTRACT_TYPE=typSmlouvy.INTERNET

# Fallback speed for unblocking when the backend has no stored original speed
DEFAULT_SPEED=0

# Payment matching (Pipeline B)
# DOCUMENTID / DOCID are per-run inputs injected by multiflexi-event-processor
LABEL_OVERPAY=PREPLATEK
LABEL_INVOICE_MISSING=CHYBIFAKTURA
LABEL_UNIDENTIFIED=NEIDENTIFIKOVANO
MATCH_OVERPAY_MODE=settle
PAYMENT_EVIDENCE=auto

# Confirmation emails (Pipeline B)
EASE_FROM=noreply@example.com
MUTE=false

# SVN Repository Configuration
SVNUSER=testuser
SVNPASS=testpass
SVNURL=https://svn.example.com/repo
SVNBIN=/usr/bin/svn
LOGFILE=/tmp/setdashboards.log

# NetBox Configuration
NETBOXURL=https://netbox.example.com
NETBOXTOKEN=testtoken
